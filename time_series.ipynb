    {
      "cell_type": "code",
      "source": [
        "\n",
        "df[\"MA_7\"]  = df[\"Close\"].rolling(window=7).mean()\n",
        "df[\"MA_30\"] = df[\"Close\"].rolling(window=30).mean()\n",
        "df[\"Rolling_Mean_30\"] = df[\"Close\"].rolling(window=30).mean()\n",
        "df[\"Rolling_Std_30\"]  = df[\"Daily_Return\"].rolling(window=30).std()\n",
        "\n",
        "forecast_df = df[[\"Close\", \"Volume\", \"MA_7\", \"MA_30\",\n",
        "                   \"Rolling_Mean_30\", \"Rolling_Std_30\"]].copy()\n",
        "forecast_df = forecast_df.dropna()\n",
        "print(forecast_df.head())\n",
        "print(forecast_df.shape)\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "plt.figure()\n",
        "plt.plot(forecast_df['Close'], label='Original')\n",
        "plt.plot(forecast_df['MA_7'], label='Moving Avg')\n",
        "plt.legend()\n",
        "plt.show()\n",
        "\n"
